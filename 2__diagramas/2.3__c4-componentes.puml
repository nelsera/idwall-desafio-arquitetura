@startuml c4-componentes
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title C4 Model - Diagrama de Componentes

' Atores
Person(usuario, "Usuário", "Solicita recomendações de gastos por período e consulta o resultado.")

' Sistemas externos
System_Ext(bancos, "APIs de Bancos Parceiros", "Fornecem as transações do usuário para a janela de datas informada.")
System_Ext(ml, "Serviço de Classificação", "Classifica transações financeiras em categorias de despesa.")

' Containers e componentes
System_Boundary(sistema, "Plataforma de Recomendação de Gastos") {

  Container_Boundary(api_container, "API") {
    Component(controller, "RecommendationController", "Node.js", "Recebe requisições de criação e consulta de recomendações.")
    Component(service, "RecommendationService", "Node.js", "Orquestra criação de solicitações e consulta de resultados.")
    Component(repository, "RequestRepository", "Node.js", "Persiste e consulta solicitações no banco.")
    Component(cache_adapter, "CacheAdapter", "Node.js", "Consulta resultados recentes no cache.")
    Component(queue_publisher, "QueuePublisher", "Node.js", "Publica tarefas de processamento na fila.")
  }

  Container_Boundary(worker_container, "Worker de Processamento") {
    Component(queue_consumer, "QueueConsumer", "Node.js", "Consome tarefas, controla tentativas e encaminha falhas definitivas.")
    Component(processor, "RecommendationProcessor", "Node.js", "Processa transações por período, solicita classificação e monta as despesas resultantes.")
    Component(bank_client, "BankClient", "Node.js", "Consulta transações por usuário e período nas APIs bancárias.")
    Component(classification_client, "ClassificationClient", "Node.js", "Envia transações para classificação.")
    Component(result_repository, "ResultRepository", "Node.js", "Atualiza status da solicitação e persiste despesas e transações classificadas de forma normalizada.")
    Component(cache_updater, "CacheUpdater", "Node.js", "Atualiza status e resultados recentes no cache.")
  }

  ContainerDb(db, "Banco de Dados", "PostgreSQL", "Armazena solicitações de recomendação, janela de consulta, status de processamento e dados normalizados de despesas e transações classificadas.")

  Container(fila, "Fila de Processamento", "RabbitMQ", "Distribui tarefas de processamento.")
  Container(dlq, "Fila de Erros (Dead Letter Queue)", "RabbitMQ", "Armazena mensagens que excederam o limite de tentativas.")
  Container(cache, "Cache", "Redis", "Armazena status e resultados recentes.")
}

' Relacionamentos
Rel(usuario, controller, "Solicita recomendações e consulta resultados", "HTTPS")

Rel(controller, service, "Chama")
Rel(service, repository, "Registra e consulta solicitações", "PostgreSQL")
Rel(service, cache_adapter, "Consulta resultados recentes", "Redis")
Rel(service, queue_publisher, "Publica tarefa", "RabbitMQ")

Rel(queue_publisher, fila, "Envia tarefa", "RabbitMQ")
Rel(queue_consumer, fila, "Consome tarefa", "RabbitMQ")
Rel(queue_consumer, dlq, "Encaminha falhas definitivas", "RabbitMQ")
Rel(queue_consumer, processor, "Entrega tarefa")

Rel(processor, bank_client, "Busca transações por período")
Rel(bank_client, bancos, "Busca transações", "HTTPS")

Rel(processor, classification_client, "Solicita classificação")
Rel(classification_client, ml, "Classifica transações", "HTTPS")

Rel(processor, result_repository, "Persiste resultados estruturados", "PostgreSQL")
Rel(processor, cache_updater, "Atualiza cache", "Redis")

Rel(repository, db, "Lê e grava solicitações", "PostgreSQL")
Rel(result_repository, db, "Atualiza status e persiste despesas e transações", "PostgreSQL")

Rel(cache_adapter, cache, "Consulta resultados recentes", "Redis")
Rel(cache_updater, cache, "Atualiza status e resultados", "Redis")

@enduml
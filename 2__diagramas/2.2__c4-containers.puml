@startuml c4-containers
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

LAYOUT_LEFT_RIGHT()

title C4 Model - Diagrama de Containers

' Atores
Person(usuario, "Usuário", "Solicita recomendações de gastos por período e consulta o resultado do processamento.")

' Sistema principal
System_Boundary(sistema, "Plataforma de Recomendação de Gastos") {

  ' Containers
  Container(api, "API", "Node.js", "Recebe id e janela de datas, registra solicitações e expõe consultas de status e resultado.")

  Container(fila, "Fila de Processamento", "RabbitMQ", "Recebe tarefas de recomendação publicadas pela API.")

  Container(dlq, "Fila de Erros (Dead Letter Queue)", "RabbitMQ", "Armazena mensagens que excederam o limite de tentativas de processamento.")

  Container(worker, "Worker de Processamento", "Node.js", "Consome tarefas, consulta transações por período, classifica despesas e persiste resultados.")

  ContainerDb(db, "Banco de Dados", "PostgreSQL", "Armazena solicitações, janela de consulta, status de processamento e dados normalizados de despesas e transações.")

  Container(cache, "Cache", "Redis", "Armazena status e resultados recentes para consultas rápidas.")
}

' Sistemas externos
System_Ext(bancos, "APIs de Bancos Parceiros", "Fornecem as transações do usuário para a janela de datas informada.")
System_Ext(ml, "Serviço de Classificação", "Classifica transações financeiras em categorias de despesa.")

' Relacionamentos
Rel(usuario, api, "Solicita recomendações e consulta resultados", "HTTPS")

Rel(api, fila, "Publica tarefas de processamento", "RabbitMQ")
Rel(api, db, "Lê e grava solicitações", "PostgreSQL")
Rel(api, cache, "Consulta dados recentes", "Redis")

Rel(worker, fila, "Consome tarefas", "RabbitMQ")
Rel(worker, dlq, "Encaminha falhas definitivas", "RabbitMQ")
Rel(worker, bancos, "Busca transações por período", "HTTPS")
Rel(worker, ml, "Classifica transações", "HTTPS")
Rel(worker, db, "Persiste resultados", "PostgreSQL")
Rel(worker, cache, "Atualiza status e resultados", "Redis")

@enduml